@{
    ViewBag.Title = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
    .input-icon-wrap { position: relative; }
    .input-icon-wrap i {
        position: absolute; left: 14px; top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted); font-size: 0.9rem;
        pointer-events: none;
    }
    .input-icon-wrap input { padding-left: 40px !important; }
</style>
}

<div class="auth-page fade-up">
    <div class="auth-card">
        <div style="text-align: center; margin-bottom: 28px;">
            <div style="width: 56px; height: 56px; border-radius: 16px; background: #FEF3C7; color: #F59E0B;
                        display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
                        margin: 0 auto 16px;">
                <i class="fa-solid fa-key"></i>
            </div>
            <h1 style="font-size: 1.8rem; margin-bottom: 8px;">Forgot Password?</h1>
            <p>Enter your email and we&rsquo;ll generate a reset link for you.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div style="padding: 12px 16px; border-radius: 10px; background: #FEE2E2; color: #991B1B;
                        border: 1px solid #FCA5A5; margin-bottom: 20px; font-size: 0.9rem;">
                <i class="fa-solid fa-circle-exclamation" style="margin-right: 6px;"></i>@TempData["Error"]
            </div>
        }

        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @class = "auth-form" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label><i class="fa-solid fa-envelope" style="color: var(--warning); margin-right: 5px;"></i> Email Address</label>
                <div class="input-icon-wrap">
                    <i class="fa-solid fa-at"></i>
                    <input type="email" name="Email" placeholder="name@example.com" required autofocus>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; border-radius: 12px; height: 50px; margin-top: 8px;">
                <i class="fa-solid fa-paper-plane" style="margin-right: 8px;"></i> Send Reset Link
            </button>
        }

        <div style="text-align: center; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border);">
            <p style="font-size: 0.95rem;">
                <a href="@Url.Action("Login", "Account")" style="color: var(--primary); font-weight: 600;">
                    <i class="fa-solid fa-arrow-left" style="margin-right: 4px;"></i> Back to Sign In
                </a>
            </p>
        </div>
    </div>
</div>
