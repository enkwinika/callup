@{
    ViewBag.Title = "Verify Your Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page fade-in">
    <div class="glass-card" style="max-width: 480px; width: 100%; padding: 48px; border-radius: 32px; text-align: center;">
        <div style="margin-bottom: 32px;">
            <div style="width: 64px; height: 64px; background: var(--bg-arctic); color: var(--primary); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin: 0 auto 24px;">
                <i class="fa-solid fa-envelope-circle-check"></i>
            </div>
            <h1 class="font-display" style="font-size: 1.8rem; margin-bottom: 8px;">Check Your Email</h1>
            <p style="color: var(--text-muted); font-size: 0.95rem;">We've sent a 6-digit verification code to<br><strong style="color: var(--text);">@ViewBag.Email</strong></p>
        </div>

        @using (Html.BeginForm("VerifyEmail", "Account", FormMethod.Post, new { id = "verifyForm" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="Email" value="@ViewBag.Email" />

            <!-- Alert Container for Feedback -->
            <div id="alertContainer" style="display: none; margin-bottom: 24px;"></div>

            <div class="form-group" style="margin-bottom: 32px;">
                <label style="font-weight: 700; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 12px; display: block; text-transform: uppercase; letter-spacing: 1px;">Verification Code</label>
                <div style="display: flex; gap: 12px; justify-content: center;" id="otp-inputs">
                    <input type="text" name="Code" class="form-control" placeholder="123456" maxlength="6" style="text-align: center; font-size: 2rem; letter-spacing: 8px; font-weight: 800; height: 72px; border-radius: 16px; width: 100%;" required autocomplete="off">
                </div>
            </div>

            <button type="submit" id="submitBtn" class="btn btn-primary" style="width: 100%; height: 56px; font-size: 1.1rem; border-radius: 16px; margin-bottom: 24px;">
                Verify Account <i class="fa-solid fa-check" style="margin-left: 10px;"></i>
            </button>
        }

        <div style="padding-top: 24px; border-top: 1px solid var(--border);">
            <p style="color: var(--text-muted); font-size: 0.9rem;">
                Didn't receive the code? <br>
                <a href="#" style="color: var(--primary); font-weight: 800;">Resend Email</a>
            </p>
        </div>
    </div>
</div>

<style>
    .alert-banner {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: 14px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid transparent;
        animation: slideDown 0.3s ease-out;
        text-align: left;
    }
    .alert-success { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
    .alert-error { background: #fee2e2; color: #991b1b; border-color: #fecaca; }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    document.getElementById('verifyForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const btn = document.getElementById('submitBtn');
        const alertBox = document.getElementById('alertContainer');
        const originalBtnHtml = btn.innerHTML;

        // Reset UI
        alertBox.style.display = 'none';
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Verifying...';

        console.log("%c[VERIFY] Submission Started", "color: #3b82f6; font-weight: bold; font-size: 1.2rem;");
        
        const form = e.target;
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        console.log("Payload:", data);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            const result = await response.json();
            console.log("%c[RESPONSE] Server Results:", "color: #10b981; font-weight: bold;", result);

            if (result.success) {
                alertBox.innerHTML = `<div class="alert-banner alert-success"><i class="fa-solid fa-circle-check"></i> ${result.message} Welcome!</div>`;
                alertBox.style.display = 'block';
                
                setTimeout(() => {
                    window.location.href = result.redirectUrl;
                }, 1500);
            } else {
                alertBox.innerHTML = `<div class="alert-banner alert-error"><i class="fa-solid fa-circle-exclamation"></i> ${result.message}</div>`;
                alertBox.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = originalBtnHtml;
                
                console.error("[VERIFY] Failed:", result.message);
            }
        } catch (error) {
            console.error("%c[FATAL] Network or Server Error:", "color: #ef4444;", error);
            alertBox.innerHTML = `<div class="alert-banner alert-error"><i class="fa-solid fa-triangle-exclamation"></i> Connection failed. Please check your console.</div>`;
            alertBox.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = originalBtnHtml;
        }
    });
</script>
