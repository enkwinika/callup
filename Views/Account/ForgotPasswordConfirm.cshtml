@{
    ViewBag.Title = "Reset Link Sent";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page fade-up">
    <div class="auth-card" style="text-align: center;">
        <div style="width: 72px; height: 72px; border-radius: 20px; background: #DCFCE7; color: #10B981;
                    display: flex; align-items: center; justify-content: center; font-size: 2rem;
                    margin: 0 auto 24px;">
            <i class="fa-solid fa-circle-check"></i>
        </div>

        <h1 style="font-size: 1.8rem; margin-bottom: 12px;">Check your email</h1>
        <p style="max-width: 320px; margin: 0 auto 32px; line-height: 1.7;">
            If <strong>@ViewBag.Email</strong> is registered, a password reset link has been sent. 
            Check your inbox (and spam folder).
        </p>

        <div style="background: #F8FAFC; border: 1px solid var(--border); border-radius: 14px; padding: 20px; margin-bottom: 28px; text-align: left;">
            <p style="font-size: 0.85rem; font-weight: 700; margin-bottom: 8px; color: var(--text);">
                <i class="fa-solid fa-circle-info" style="color: var(--primary); margin-right: 6px;"></i>
                Demo Mode
            </p>
            <p style="font-size: 0.85rem; color: var(--text-muted);">
                Your reset token: <code style="background: #EEF2FF; padding: 2px 8px; border-radius: 6px; color: var(--primary); font-weight: 700;">@ViewBag.Token</code>
            </p>
        </div>

        <a href="@Url.Action("Login", "Account")" class="btn btn-primary" style="border-radius: 12px; padding: 12px 32px;">
            <i class="fa-solid fa-right-to-bracket" style="margin-right: 8px;"></i> Back to Sign In
        </a>
    </div>
</div>
