@{
    ViewBag.Title = "Payment Successful";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="result-hero-wrap d-flex align-items-center justify-content-center" style="min-height: 90vh; padding: 60px 20px; width: 100%;">
    <div class="result-hero-container text-center" style="max-width: 580px; width: 100%; margin: 0 auto;">
        
        <!-- Brand Identity -->
        <div class="brand-logo-fade mb-5 pb-4">
            <img src="@Url.Content("~/Content/img/brand/logo-main.png")?v=@DateTime.Now.Ticks" alt="CallUp" style="height: 80px; filter: drop-shadow(0 15px 30px rgba(0,0,0,0.08));">
        </div>

        <!-- Hero Content -->
        <div class="premium-result-card animate__animated animate__fadeInUp" style="background: white; border-radius: 40px; box-shadow: 0 60px 120px -20px rgba(15, 23, 42, 0.15); padding: 80px 48px; border: 1px solid var(--border); position: relative; overflow: visible;">
            
            <div class="success-seal-wrap mb-5">
                <div class="seal-outer">
                    <div class="seal-inner">
                        <i class="fa-solid fa-check"></i>
                    </div>
                </div>
            </div>

    <br/>
    <br/>
            <div class="title-wrap mb-4">
                <h1 class="font-display" style="font-size: 3.2rem; color: #0F172A; letter-spacing: -0.05em; font-weight: 850; line-height: 1;">Payment Secured</h1>
            </div>
    <br/>
    <br/>
            <div class="message-wrap mb-5">
                <p class="text-muted mx-auto" style="font-size: 1.2rem; line-height: 1.6; max-width: 420px; font-weight: 500;">
                    Great news! Your request for <span class="fw-bold text-dark">@ViewBag.RequestTitle</span> is now confirmed and in progress.
                </p>
            </div>

    <br/>
    <br/>
            <!-- Modern Digital Receipt -->
            <div class="digital-receipt p-4 text-start mb-5" style="background: rgba(248, 250, 252, 0.8); border: 2px solid #F1F5F9; border-radius: 24px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 800; color: #94A3B8;">Job Reference</span>
                    <span class="font-display" style="font-size: 1.1rem; font-weight: 700; color: #0F172A;">REQ-@ViewBag.RequestId</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 800; color: #94A3B8;">Gateway Status</span>
                    <div style="font-weight: 800; color: #10B981; gap: 8px; font-size: 0.95rem; text-align: center">
                       
    <br />
     <i class="fa-solid fa-circle-check"></i> VERIFIED SUCCESS
    <br/> <br/>
                    </div>
                </div>
            </div>

    <br/>
    <br/>
            <div class="action-footer mt-4">
                <a href="@Url.Action("Customer", "Dashboard")" class="btn btn-hero-primary px-5 py-4 w-100" style="background: #4F46E5; color: white; border-radius: 20px; font-weight: 700; font-size: 1.15rem; letter-spacing: 0.01em; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 20px 40px rgba(79, 70, 229, 0.25); text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 12px; border: none;">
                    Track My Request
                    <i class="fa-solid fa-arrow-right-long animate-arrow"></i>
                </a>
            </div>
        </div>

        <div class="help-text mt-5 pt-3 opacity-75">
            <span class="text-muted font-display" style="font-weight: 500;">Need a copy of your invoice?</span>
            <a href="#" class="ms-2 fw-bold text-dark text-decoration-none border-bottom border-2 border-primary">Contact Support</a>
        </div>
    </div>
</div>

<style>
    .font-display { font-family: 'Outfit', sans-serif; }
    
    .seal-outer {
        width: 110px;
        height: 110px;
        background: #ECFDF5;
        border-radius: 36% 64% 70% 30% / 30% 30% 70% 70%;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: sealPulse 3s infinite ease-in-out;
    }
    
    .seal-inner {
        width: 68px;
        height: 68px;
        background: #10B981;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        box-shadow: 0 12px 24px rgba(16, 185, 129, 0.25);
    }

    .btn-hero-primary:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 30px 60px rgba(79, 70, 229, 0.35);
        background: #4338CA;
    }

    .animate-arrow { transition: transform 0.3s; }
    .btn-hero-primary:hover .animate-arrow { transform: translateX(10px); }

    @@keyframes sealPulse {
        0%, 100% { border-radius: 36% 64% 70% 30% / 30% 30% 70% 70%; transform: scale(1); }
        50% { border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%; transform: scale(1.08); }
    }

    .brand-logo-fade {
        animation: fadeInDown 1.2s cubic-bezier(0.19, 1, 0.22, 1);
    }

    @@media (max-width: 768px) {
        .premium-result-card { padding: 50px 24px; }
        h1 { font-size: 2.5rem !important; }
        .result-hero-wrap { padding-top: 20px; }
    }
</style>
