        <div class="profile-avatar-lg" style="background: var(--primary);"><i class="fa-solid fa-gear" style="font-size:1.5rem;"></i></div>
        <div class="profile-hero-info">
            <h2 class="profile-hero-name">Settings</h2>
            <p class="profile-hero-email">Manage your preferences and notification settings</p>
        </div>
    </div>

    <div class="profile-grid fade-up" style="animation-delay:0.1s;">

        <!-- Notification Preferences -->
