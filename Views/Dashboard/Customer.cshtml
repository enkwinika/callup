                    <label class="toggle-switch">
                        <input type="checkbox" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="settings-toggle-row">
                    <div>
                        <div class="settings-toggle-label">Job Started</div>
                        <div class="settings-toggle-desc">When a provider begins work on your job</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="settings-toggle-row">
                    <div>
                        <div class="settings-toggle-label">Job Completed</div>
                        <div class="settings-toggle-desc">When a provider marks work as done</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="settings-toggle-row">
                    <div>
                        <div class="settings-toggle-label">Promotions & Tips</div>
                        <div class="settings-toggle-desc">Helpful service tips and special offers</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox">
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Communication -->
        <div class="card-section">
            <div class="table-header">
                <div><h3>Communication</h3><p>How we reach you</p></div>
                <i class="fa-solid fa-envelope" style="color:var(--secondary);font-size:1.2rem;opacity:0.4;"></i>
            </div>
            <div style="padding: 28px;">
                <div class="settings-toggle-row">
                    <div>
                        <div class="settings-toggle-label">Email Notifications</div>
                        <div class="settings-toggle-desc">Receive updates at @User.Identity.Name</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" checked>
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="settings-toggle-row">
                    <div>
                        <div class="settings-toggle-label">SMS Alerts</div>
                        <div class="settings-toggle-desc">Critical updates via text message</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox">
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="settings-toggle-row">
                    <div>
                        <div class="settings-toggle-label">In-App Notifications</div>
                        <div class="settings-toggle-desc">Shown in your dashboard bell icon</div>
                    </div>
