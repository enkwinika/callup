@model IEnumerable<CallUp.Models.ServiceRequest>
@{
    ViewBag.Title = "My Dashboard";
    string role = ViewBag.UserRole ?? "Customer";
}

<div class="dash-header fade-up">
    <div>
        <h1 id="pageTitle" style="font-size: 2.5rem; margin-bottom: 6px;">My Requests</h1>
        <p id="pageSubtitle">You have <strong>@Model.Count(r => r.Status != "Completed")</strong> active requests.</p>
    </div>
    <button class="btn btn-primary" onclick="$('#newRequestModal').addClass('active'); $('body').addClass('modal-open');" id="newRequestBtn">
        <i class="fa-solid fa-plus"></i> New Request
    </button>
</div>

<!-- Stats Grid -->
<div class="stats-grid fade-up" style="animation-delay: 0.1s;">
    <div class="stat-card-v2">
        <div class="stat-icon-v2 bg-indigo"><i class="fa-solid fa-paper-plane"></i></div>
        <div class="stat-info">
            <span class="stat-value">@Model.Count(r => r.Status != "Completed" && r.Status != "Closed" && r.Status != "Rejected")</span>
            <span class="stat-label">Active Requests</span>
        </div>
    </div>
    <div class="stat-card-v2">
        <div class="stat-icon-v2 bg-emerald"><i class="fa-solid fa-circle-check"></i></div>
        <div class="stat-info">
            <span class="stat-value">@Model.Count(r => r.Status == "Completed")</span>
            <span class="stat-label">Total Jobs Done</span>
        </div>
    </div>
    <div class="stat-card-v2">
        <div class="stat-icon-v2 bg-amber"><i class="fa-solid fa-star"></i></div>
        <div class="stat-info">
            <span class="stat-value">4.9</span>
            <span class="stat-label">Your Rating</span>
        </div>
    </div>
</div>

<!-- View Sections -->
<div class="view-section active" id="view-requests">
    <div class="card-section fade-up" style="animation-delay: 0.2s;">
        <div class="table-header">
            <h3>Active Requests</h3>
        </div>
        
        @if (!Model.Any())
        {
            <div style="text-align: center; padding: 100px 40px;">
                <div style="font-size: 4rem; color: var(--border); margin-bottom: 24px;"><i class="fa-solid fa-folder-open"></i></div>
                <h3 style="margin-bottom: 12px;">No active requests</h3>
                <p style="margin-bottom: 32px;">Need something fixed? Post a request and get bids in minutes.</p>
                <button class="btn btn-outline" onclick="$('#newRequestModal').addClass('active'); $('body').addClass('modal-open');">Get Bids Now</button>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Service Needed</th>
                        <th>Status</th>
                        <th>Views</th>
                        <th>Bids</th>
                        <th>Request Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Where(r => r.Status != "Completed" && r.Status != "Closed" && r.Status != "Cancelled" && r.Status != "Rejected" && r.Status != "PendingConfirmation"))
                    {
                        <tr>
                            <td>
                                <div style="font-weight: 700;">@(string.IsNullOrEmpty(item.Title) ? item.Description : item.Title)</div>
                                <div style="font-size: 0.85rem; color: var(--text-muted);"><i class="fa-solid fa-location-dot"></i> @item.Location</div>
                            </td>
                            <td>
                                <span class="status-badge status-@(item.Status.ToLower().Replace(" ", "-"))">
                                    @item.Status
                                </span>
                            </td>
                            <td style="text-align: center; font-weight: 600;">@item.ViewCount</td>
                            <td style="text-align: center; font-weight: 600;">@item.BidCount</td>
                            <td style="color: var(--text-muted);">@item.CreatedAt.ToString("dd MMM, HH:mm")</td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <button class="btn btn-outline btn-sm" onclick="viewRequestDetails(@item.Id, '@(item.Title ?? item.Description)', '@item.Status')">Manage</button>
                                    
                                    @if (item.Status == "InProgress" || item.Status == "Completed" || item.Status == "PendingConfirmation" || item.Status == "Closed")
                                    {
                                        <a href="@Url.Action("Invoice", "Document", new { id = item.Id })" target="_blank" class="btn btn-outline btn-sm" style="color: var(--secondary); border-color: var(--secondary); gap: 6px;">
                                            <i class="fa-solid fa-download"></i> Invoice
                                        </a>
                                    }
                                    @if (item.Status == "Open" || item.Status == "Moderation")
                                    {
                                        <button class="btn btn-sm" style="color: var(--error); border-color: transparent;" onclick="cancelRequest(@item.Id)">Cancel</button>
                                    }
                                    @if (item.Status == "PendingPayment")
                                    {
                                        <button class="btn btn-primary btn-sm" onclick="processPayment(@item.Id)">Pay Now</button>
                                    }
                                    @if (item.Status == "Completed") 
                                    {
                                        <button class="btn btn-primary btn-sm" onclick="openRatingModal(@item.Id, '@item.Title')">Rate</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@* ── FIND A SERVICE ── *@
<div class="view-section" id="view-find-service">

    <!-- Hero Search -->
    <div class="find-service-hero fade-up">
        <h2 class="find-service-title">Find the Right Professional</h2>
        <p class="find-service-sub">Search by trade or skill — book directly or post for bids</p>
        <div class="find-service-search-bar">
            <i class="fa-solid fa-magnifying-glass" style="color: var(--text-muted);"></i>
            <input type="text" id="providerSearchInput" placeholder="e.g. Plumber, Electrician, Cleaner..." autocomplete="off">
            <button class="btn btn-primary" onclick="searchProviders()" id="searchProvidersBtn">
                <i class="fa-solid fa-magnifying-glass"></i> Search
            </button>
            <button class="btn btn-outline" id="toggleMapViewBtn" onclick="toggleMapView()" style="margin-left: 10px; width: 50px; padding: 0;" title="Map View">
                <i class="fa-solid fa-map-location-dot"></i>
            </button>
        </div>

        <div id="serviceMapPanel" class="glass-card fade-up" style="display: none; height: 400px; margin-top: 30px; overflow: hidden; padding: 0; border-radius: 20px;">
            <div id="googleMap" style="height: 100%; width: 100%;"></div>
        </div>
        <!-- Quick category pills -->
        <div class="find-service-cats">
            <button class="cat-pill" onclick="quickSearch('Plumber')"><i class="fa-solid fa-wrench"></i> Plumber</button>
            <button class="cat-pill" onclick="quickSearch('Electrician')"><i class="fa-solid fa-bolt"></i> Electrician</button>
            <button class="cat-pill" onclick="quickSearch('Cleaner')"><i class="fa-solid fa-broom"></i> Cleaner</button>
            <button class="cat-pill" onclick="quickSearch('Painter')"><i class="fa-solid fa-paint-roller"></i> Painter</button>
            <button class="cat-pill" onclick="quickSearch('Gardener')"><i class="fa-solid fa-leaf"></i> Gardener</button>
            <button class="cat-pill" onclick="quickSearch('Handyman')"><i class="fa-solid fa-screwdriver-wrench"></i> Handyman</button>
        </div>
    </div>

    <!-- Two Column Layout: Results + Post a Request -->
    <div class="find-service-grid">

        <!-- Provider Results -->
        <div id="providersPanel">
            <div class="card-section">
                <div class="table-header">
                    <div>
                        <h3 id="providerResultsTitle">Available Providers</h3>
                        <p>Tap a provider to request their service directly</p>
                    </div>
                    <span id="providerCount" style="font-size: 0.85rem; color: var(--text-muted);"></span>
                </div>
                <div id="providerResults" style="padding: 24px;">
                    <div class="empty-state">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <p>Search above to find professionals in your area</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post a Request (Bid Form) -->
        <!-- Request assistance banner -->
        <div>
            <div class="card-section" style="background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; border: none; overflow: hidden; position: relative;">
                <div style="padding: 40px; position: relative; z-index: 2;">
                    <h3 style="color: white; font-size: 1.8rem; margin-bottom: 8px;">Need something else?</h3>
                    <p style="color: rgba(255,255,255,0.8); margin-bottom: 24px;">Post a new request and let our verified professionals come to you with competitive bids.</p>
                    <button class="btn btn-light" onclick="$('#newRequestModal').addClass('active'); $('body').addClass('modal-open');" style="background: white; color: var(--primary); font-weight: 700; border: none; height: 50px; padding: 0 32px; border-radius: 12px; transition: 0.3s; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">
                        <i class="fa-solid fa-plus"></i> Create New Request
                    </button>
                </div>
                <i class="fa-solid fa-tools" style="position: absolute; right: -20px; bottom: -20px; font-size: 12rem; color: rgba(255,255,255,0.1); transform: rotate(-15deg);"></i>
            </div>
        </div>

    </div>
</div>

@* ── CUSTOMER SETTINGS ── *@
