@model IEnumerable<CallUp.Models.ServiceRequest>
@using System.Linq
@{
    ViewBag.Title = "Provider Dashboard";
}

<div class="dash-header fade-up">
    <div>
        <h1 id="pageTitle" style="font-size: 2.5rem; margin-bottom: 8px;">Opportunities</h1>
        <p>Your business status: 
            @if (ViewBag.IsApproved == true)
            {
                <span class="badge badge-active"><i class="fa-solid fa-circle-check"></i> Verified & Approved</span>
            }
            else
            {
                <span class="badge badge-pending" style="background: #FFFBEB; color: #B45309; border: 1px solid #FDE68A;"><i class="fa-solid fa-clock"></i> Pending Approval</span>
            }
        </p>
    </div>
    <div style="text-align: right;">
        <div style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 4px;">Business Balance</div>
        <div style="font-size: 1.5rem; font-weight: 800; color: #10B981;">R @((ViewBag.TotalEarned ?? 0).ToString("N2"))</div>
    </div>
</div>

@if (ViewBag.IsApproved != true)
{
    <div class="glass-card fade-up" style="margin-bottom: 32px; background: linear-gradient(135deg, #FFFBEB, #FEF3C7); border: 1px solid #FDE68A; padding: 24px; border-radius: 20px; display: flex; align-items: center; gap: 24px;">
        <div style="width: 60px; height: 60px; background: white; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #D97706; box-shadow: var(--shadow-sm);">
            <i class="fa-solid fa-user-shield"></i>
        </div>
        <div style="flex: 1;">
            <h3 style="color: #92400E; margin-bottom: 4px;">Account Pending Verification</h3>
            <p style="color: #B45309; margin: 0; font-size: 0.95rem;">Our administration team is currently reviewing your profile and documents. You will be notified via email once you are approved to submit bids and start earning.</p>
        </div>
    </div>
}

<!-- Business Performance Stats -->
<div class="stats-grid fade-up" style="margin-top: -20px; margin-bottom: 40px; animation-delay: 0.1s;">
    <div class="stat-card">
        <div class="stat-icon" style="background: var(--primary-light); color: var(--primary);">
            <i class="fa-solid fa-briefcase"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">@(ViewBag.ActiveJobs ?? 0)</div>
            <div class="stat-label">Active Jobs</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: #ECFDF5; color: #10B981;">
            <i class="fa-solid fa-sack-dollar"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">@(ViewBag.JobsWon ?? 0)</div>
            <div class="stat-label">Lifetime Wins</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: #FFFBEB; color: #F59E0B;">
            <i class="fa-solid fa-star"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">@(ViewBag.AvgRating > 0 ? ViewBag.AvgRating.ToString("N1") : "New")</div>
            <div class="stat-label">Rating (@(ViewBag.ReviewCount ?? 0) Reviews)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: #EFF6FF; color: #3B82F6;">
            <i class="fa-solid fa-bullseye"></i>
        </div>
        <div class="stat-info">
            @{
                int bids = ViewBag.BidsPlaced ?? 0;
                int wins = ViewBag.JobsWon ?? 0;
                double winRate = bids > 0 ? (double)wins / bids * 100 : 0;
            }
            <div class="stat-value">@winRate.ToString("N0")%</div>
            <div class="stat-label">Win Rate (@bids Bids)</div>
        </div>
    </div>
</div>

<style>
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; position: relative; z-index: 5; }
    .stat-card { 
        background: rgba(255, 255, 255, 0.7); 
        backdrop-filter: blur(10px);
        padding: 24px; 
        border-radius: 20px; 
        border: 1px solid rgba(255, 255, 255, 0.5);
        display: flex; 
        align-items: center; 
        gap: 20px;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
    }
    .stat-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); border-color: var(--primary-light); }
    .stat-icon { width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .stat-value { font-size: 1.5rem; font-weight: 800; color: var(--text-main); line-height: 1.2; }
    .stat-label { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
</style>



<div class="view-section active" id="view-opportunities">
    <div class="card-section fade-up" style="animation-delay: 0.2s;">
        <div class="table-header">
            <h3>Nearby Opportunities</h3>
            <span style="font-size: 0.85rem; color: var(--secondary); font-weight: 600;">
                <i class="fa-solid fa-circle-dot"></i> Live Feed
            </span>
        </div>
        
        <div style="padding: 24px;">
            @if (Model != null && Model.Any())
            {
                foreach (var opp in Model)
                {
                    <div class="glass-card fade-up" style="margin-bottom: 24px; padding: 32px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.4);">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
                            <div>
                                <h2 style="margin-bottom: 8px;">@opp.Title</h2>
                                <div style="display: flex; gap: 12px; align-items: center;">
                                    <span class="badge badge-pending">@opp.CategoryName</span>
                                    <span style="color: var(--text-muted); font-size: 0.9rem; cursor: pointer; border-bottom: 1px dashed var(--border);" 
                                          title="View on Map" 
                                          onclick="showJobMap(@(opp.Latitude ?? 0), @(opp.Longitude ?? 0), '@opp.Title')">
                                        <i class="fa-solid fa-location-dot" style="color: var(--primary);"></i> @opp.Location
                                    </span>
                                    @if (opp.DistanceInKm.HasValue)
                                    {
                                        <span style="background: #FFF7ED; color: #C2410C; font-size: 0.75rem; padding: 2px 8px; border-radius: 6px; font-weight: 700; border: 1px solid #FFEDD5;">
                                            <i class="fa-solid fa-route"></i> @opp.DistanceInKm.Value.ToString("N1") km away
                                        </span>
                                    }
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-weight: 700; color: var(--primary); font-size: 1.2rem;">@opp.PriceRange</div>
                                <div style="font-size: 0.8rem; color: var(--text-muted);">Budget Range</div>
                            </div>
                        </div>
                        
                        <p style="margin-bottom: 20px; font-size: 1.05rem;">"@opp.Description"</p>
                        
                        @if (opp.ImagePaths != null && opp.ImagePaths.Any())
                        {
                            <div style="display: flex; gap: 12px; margin-bottom: 24px; overflow-x: auto; padding-bottom: 8px;">
                                @foreach (var imgPath in opp.ImagePaths)
                                {
                                    var fullPath = imgPath.StartsWith("~") ? Url.Content(imgPath) : imgPath;
                                    <div style="flex-shrink: 0; width: 140px; height: 100px; border-radius: 12px; overflow: hidden; border: 1px solid var(--border); box-shadow: var(--shadow-sm); cursor: pointer;" 
                                         onclick="window.open('@fullPath', '_blank')">
                                        <img src="@fullPath" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;" 
                                             onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                                    </div>
                                }
                            </div>
                        }
                        
                        <div style="display: flex; gap: 16px;">
                            <div style="display: flex; gap: 16px; align-items: center; width: 100%;">
                                @if (ViewBag.IsApproved == true)
                                {
                                    <button class="btn btn-primary" style="flex: 1;" onclick="openBidModal(@opp.Id, '@opp.Title')">Submit Bid</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline" style="flex: 1; cursor: not-allowed; opacity: 0.6; border-style: dashed;" disabled title="Your account is pending administrator approval.">
                                        <i class="fa-solid fa-lock"></i> Submit Bid (Pending Approval)
                                    </button>
                                }
                                <div style="display: flex; gap: 12px; color: var(--text-muted); font-size: 0.9rem; font-weight: 600;">
                                    <span><i class="fa-solid fa-eye"></i> @opp.ViewCount Views</span>
                                    <span><i class="fa-solid fa-hand-holding-dollar"></i> @opp.BidCount Bids</span>
                                </div>
                            @if (opp.LowestBid.HasValue)
                            {
                                <div style="font-size: 0.85rem; padding: 8px 16px; background: #F0FDFA; color: #0D9488; border-radius: 10px; font-weight: 600;">
                                    Lowest: R @opp.LowestBid.Value.ToString("N2")
                                </div>
                            }
                        </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 60px; color: var(--text-muted);">
                    <i class="fa-solid fa-magnifying-glass" style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"></i>
                    <p>No new opportunities in your area right now. We'll notify you when someone needs your help!</p>
                </div>
            }
        </div>
    </div>
</div>

@* ── Bid Submission Modal ── *@
<div id="bidModal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.6); backdrop-filter:blur(4px); z-index:2000; align-items:center; justify-content:center;">
    <div class="auth-card fade-up" style="max-width: 500px; width: 90%;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
            <h2 id="bidTitle" style="font-size: 1.4rem;">Submit Bid</h2>
            <button onclick="$('#bidModal').fadeOut()" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        @using (Html.BeginForm("PlaceBid", "Provider", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="requestId" id="bidRequestId">
            <div class="form-group" style="margin-bottom: 20px;">
                <label>Your Bid Amount (R)</label>
                <input type="number" name="amount" step="0.01" required placeholder="e.g. 450.00" style="width:100%; border:1px solid var(--border); border-radius:12px; padding:12px;">
            </div>
            <div class="form-group" style="margin-bottom: 20px;">
                <label>Arrival Date / ETA</label>
                <input type="text" name="eta" required placeholder="e.g. Tomorrow at 10am" style="width:100%; border:1px solid var(--border); border-radius:12px; padding:12px;">
            </div>
            <div class="form-group" style="margin-bottom: 24px;">
                <label>Cover Note / Comments</label>
                <textarea name="notes" placeholder="Why should they choose you?" style="width:100%; min-height:100px; border:1px solid var(--border); border-radius:12px; padding:12px;"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; height:50px; border-radius:12px;">Send Bid</button>
        }
    </div>
</div>

<div class="view-section" id="view-my-jobs">
    <div class="card-section fade-up">
        <div class="table-header"><h3>Active Jobs & Work Orders</h3></div>
        <div style="padding: 24px;">
            <!-- Active Jobs & Work Orders -->
            @if (ViewBag.MyJobs != null && ((IEnumerable<CallUp.Models.ServiceRequest>)ViewBag.MyJobs).Any())
            {
                foreach (var job in (IEnumerable<CallUp.Models.ServiceRequest>)ViewBag.MyJobs)
                {
                    <div class="glass-card" style="margin-bottom: 24px; padding: 28px; border-radius: 20px; border: 1px solid var(--border); box-shadow: 0 4px 6px -1px var(--bg-primary);">
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 16px;">
                            <div>
                                <h3 style="margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--text);">@job.Title</h3>
                                <div style="display: flex; gap: 16px; margin-top: 8px; font-size: 0.85rem; color: var(--text-muted);">
                                    <span><i class="fa-solid fa-location-dot" style="color: var(--primary);"></i> @job.Location</span>
                                    <span><i class="fa-solid fa-calendar-check" style="color: var(--secondary);"></i> ETA: @(string.IsNullOrEmpty(job.ETA) ? "TBD" : job.ETA)</span>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-weight: 800; font-size: 1.3rem; color: var(--success);">R @job.Amount.ToString("N2")</div>
                                <span class="badge @(job.Status == "InProgress" ? "badge-active" : "badge-pending")" style="margin-top: 8px;">@job.Status</span>
                            </div>
                        </div>

                        @{
                            var steps = new Dictionary<string, int> {
                                { "Moderation", 0 }, { "Open", 1 }, { "PendingPayment", 2 },
                                { "InProgress", 3 }, { "PendingConfirmation", 4 }, { "PendingApproval", 4 },
                                { "Completed", 5 }, { "Paid", 5 }
                            };
                            int currentStep = steps.ContainsKey(job.Status) ? steps[job.Status] : 0;
                            double progress = (currentStep / 5.0) * 100;
                        }

                        <div style="margin: 20px 0 35px 0; background: rgba(0,0,0,0.02); padding: 15px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                            <div class="timeline-stepper">
                                <div class="timeline-progress-bar" style="width: @progress%;"></div>
                                <div class="timeline-step @(currentStep == 0 ? "active" : (currentStep > 0 ? "completed" : ""))">
                                    <div class="step-bubble"><i class="fa-solid fa-file-shield"></i></div>
                                    <span class="step-label">Posted</span>
                                </div>
                                <div class="timeline-step @(currentStep == 1 ? "active" : (currentStep > 1 ? "completed" : ""))">
                                    <div class="step-bubble"><i class="fa-solid fa-users-viewfinder"></i></div>
                                    <span class="step-label">Bidding</span>
                                </div>
                                <div class="timeline-step @(currentStep == 2 ? "active" : (currentStep > 2 ? "completed" : ""))">
                                    <div class="step-bubble"><i class="fa-solid fa-credit-card"></i></div>
                                    <span class="step-label">Payment</span>
                                </div>
                                <div class="timeline-step @(currentStep == 3 ? "active" : (currentStep > 3 ? "completed" : ""))">
                                    <div class="step-bubble"><i class="fa-solid fa-hammer"></i></div>
                                    <span class="step-label">Started</span>
                                </div>
                                <div class="timeline-step @(currentStep == 4 ? "active" : (currentStep > 4 ? "completed" : ""))">
                                    <div class="step-bubble"><i class="fa-solid fa-clipboard-check"></i></div>
                                    <span class="step-label">Review</span>
                                </div>
                                <div class="timeline-step @(currentStep == 5 ? "active" : (currentStep > 5 ? "completed" : ""))">
                                    <div class="step-bubble"><i class="fa-solid fa-circle-check"></i></div>
                                    <span class="step-label">Done</span>
                                </div>
                            </div>
                        </div>
                        
                        <div style="margin-bottom: 24px;">
                            <p style="margin-bottom: 16px; font-size: 0.95rem; color: #475569;">"@job.Description"</p>
                            
                            @if (job.ImagePaths != null && job.ImagePaths.Any())
                            {
                                <div style="display: flex; gap: 8px; margin-bottom: 12px; overflow-x: auto; padding-bottom: 8px;">
                                    @foreach (var imgPath in job.ImagePaths)
                                    {
                                        var fullPath = imgPath.StartsWith("~") ? Url.Content(imgPath) : imgPath;
                                        <div style="flex-shrink: 0; width: 100px; height: 75px; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); box-shadow: var(--shadow-sm); cursor: pointer;" 
                                             onclick="window.open('@fullPath', '_blank')">
                                            <img src="@fullPath" style="width: 100%; height: 100%; object-fit: cover;">
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
                            <div style="background: var(--bg-arctic); padding: 16px; border-radius: 12px; border: 1px solid var(--border);">
                                <h4 style="margin: 0 0 12px 0; font-size: 0.85rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px;">Customer Details</h4>
                                <div style="font-weight: 700;">@job.CustomerName</div>
                                <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 8px;">
                                    <div style="font-size: 0.9rem;">
                                        <i class="fa-solid fa-phone" style="width: 20px; color: var(--primary);"></i> @job.CustomerPhone
                                    </div>
                                    <div style="font-size: 0.9rem;">
                                        <i class="fa-solid fa-envelope" style="width: 20px; color: var(--secondary);"></i> @job.CustomerEmail
                                    </div>
                                </div>
                            </div>
                            <div style="display: flex; gap: 12px; align-items: flex-end; justify-content: flex-end;">
                                @if (job.Status == "Accepted" || job.Status == "PendingPayment")
                                {
                                    <div style="font-size: 0.8rem; color: var(--text-muted); font-style: italic; margin-bottom: 15px;">
                                        Waiting for customer to secure funds...
                                    </div>
                                }
                                <div style="display:flex; gap:10px;">
                                    <a href="@Url.Action("PurchaseOrder", "Document", new { id = job.Id })" target="_blank" class="btn btn-outline" style="border-radius: 10px; height: 46px; border-color: var(--secondary); color: var(--secondary); padding: 0 20px; display: flex; align-items: center; gap: 8px;">
                                        <i class="fa-solid fa-download"></i> Download PO
                                    </a>
                                    @if (job.Status == "InProgress")
                                    {
                                        <button class="btn btn-success" onclick="openCompleteModal(@job.Id)" style="border-radius: 10px; height: 46px; padding: 0 24px;">
                                            <i class="fa-solid fa-check-double"></i> Complete Job
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

            @if ((ViewBag.MyJobs == null || !((IEnumerable<CallUp.Models.ServiceRequest>)ViewBag.MyJobs).Any()))
            {
                <div style="text-align: center; padding: 40px; color: var(--text-muted); opacity: 0.5;">
                    <i class="fa-solid fa-list-check" style="font-size: 2rem; margin-bottom: 12px;"></i>
                    <p>No active jobs at the moment.</p>
                </div>
            }
        </div>
    </div>
</div>

@* ── Job Completion Modal ── *@
<div id="completeModal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.6); backdrop-filter:blur(4px); z-index:2100; align-items:center; justify-content:center;">
    <div class="auth-card fade-up" style="max-width: 500px; width: 90%;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
            <h2 style="font-size: 1.4rem;">Job Completion</h2>
            <button onclick="$('#completeModal').fadeOut()" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <form id="completeForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="requestId" id="completeRequestId">
            
            <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 20px;">
                Please upload proof of your completed work (e.g. photos of the cleaned area or finished repairs). 
            </p>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="font-weight: 700; display: block; margin-bottom: 8px;">Completion Notes / Comments</label>
                <textarea name="completionNotes" placeholder="Describe the work finished, any issues encountered, etc." style="width: 100%; height: 100px; padding: 12px; border-radius: 12px; border: 1px solid var(--border); font-family: inherit; font-size: 0.9rem;"></textarea>
            </div>

            <div class="form-group" style="margin-bottom: 24px;">
                <label style="font-weight: 700; display: block; margin-bottom: 8px;">Upload Completion Proof (Max 2 - Optional)</label>
                <div style="border: 2px dashed var(--border); padding: 20px; border-radius: 12px; text-align: center;">
                    <i class="fa-solid fa-cloud-arrow-up" style="font-size: 2rem; color: var(--primary); margin-bottom: 12px;"></i>
                    <input type="file" name="proofImages" id="proofImages" multiple accept="image/*" style="width: 100%;">
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; height:54px; border-radius:12px; font-weight: 700;">
                Submit for Confirmation
            </button>
        </form>
    </div>
</div>

<div class="view-section" id="view-messages">
    <div class="card-section">
        <div class="table-header"><h3>Messages</h3></div>
        <div style="padding: 24px;">
            @if (ViewBag.Messages != null && ((IEnumerable<dynamic>)ViewBag.Messages).Any())
            {
                foreach (var msg in (IEnumerable<dynamic>)ViewBag.Messages)
                {
                    bool isUnread = !msg.IsRead;
                    <div class="glass-card @(isUnread ? "unread-message" : "")" style="margin-bottom: 16px; padding: 20px; border-radius: 16px; display: flex; align-items: center; gap: 16px; border: 1px solid @(isUnread ? "var(--primary)" : "var(--primary-light)"); background: @(isUnread ? "rgba(var(--primary-rgb), 0.05)" : "rgba(var(--primary-rgb), 0.02)"); position: relative;">
                        @if (isUnread)
                        {
                            <div style="position: absolute; top: 12px; right: 20px; width: 10px; height: 10px; background: var(--primary); border-radius: 50%;" title="New message"></div>
                        }
                        <div class="user-avatar" style="width: 50px; height: 50px; background: var(--primary);">@msg.SenderName.Substring(0, 1)</div>
                        <div style="flex: 1;">
                            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 4px;">
                                <h4 style="margin: 0; font-weight: 700;">@msg.SenderName <span class="status-badge provider" style="font-size: 0.65rem; padding: 2px 6px; margin-left: 8px;">@msg.Role</span></h4>
                                <span style="font-size: 0.75rem; color: var(--text-muted);">@msg.Time</span>
                            </div>
                            <p style="margin: 0; font-size: 0.9rem; color: var(--text-dark);">"@msg.Message"</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="padding: 40px; text-align: center; color: var(--text-muted); opacity: 0.5;">
                    <i class="fa-solid fa-message" style="font-size: 2rem; margin-bottom: 12px;"></i>
                    <p style="font-size: 0.85rem;">You have no messages yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="view-section" id="view-earnings">
    <div class="card-section">
        <div class="table-header">
            <div>
                <h3>Earnings & Payouts</h3>
                <p>History of your successful payouts and upcoming earnings</p>
            </div>
            <div style="text-align: right;">
                <div style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700;">Life to Date Payouts</div>
                <div style="font-size: 1.2rem; font-weight: 800; color: #10B981;">R @((ViewBag.TotalEarned ?? 0).ToString("N2"))</div>
            </div>
        </div>
        
        <div style="padding: 24px;">
            <div style="overflow-x: auto;">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Reference</th>
                            <th>Description</th>
                            <th style="text-align: right;">Job Value</th>
                            <th style="text-align: right; color: #ef4444;">Fee (5%)</th>
                            <th style="text-align: right; color: var(--primary);">Your Earning</th>
                            <th style="text-align: center;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Earnings != null && ((IEnumerable<dynamic>)ViewBag.Earnings).Any())
                        {
                            foreach (var ear in (IEnumerable<dynamic>)ViewBag.Earnings)
                            {
                                <tr>
                                    <td style="font-size: 0.85rem; color: var(--text-muted);">@ear.Date</td>
                                    <td><code style="font-size: 0.7rem; color: var(--text-muted);">PAY-MBR-@ear.Project.GetHashCode().ToString("X")</code></td>
                                    <td style="font-weight: 600;">@ear.Project</td>
                                    <td style="text-align: right; font-size: 0.9rem; color: var(--text-muted);">R @ear.Total.ToString("N2")</td>
                                    <td style="text-align: right; color: #ef4444; font-size: 0.9rem;">- R @ear.Fee.ToString("N2")</td>
                                    <td style="text-align: right; font-weight: 800; color: #10B981; font-size: 1.1rem;">R @ear.Amount.ToString("N2")</td>
                                    <td style="text-align: center;">
                                        <span class="pill @(ear.Status == "Paid" ? "pill-success" : ear.Status == "Pending Approval" ? "pill-warning" : "pill-info")" style="font-size: 0.65rem; padding: 4px 10px;">
                                            @ear.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" style="text-align:center; padding: 60px; color: var(--text-muted); opacity: 0.5;">
                                    <i class="fa-solid fa-receipt fa-2x" style="display: block; margin-bottom: 12px;"></i>
                                    No earnings history yet. Complete a job to start earning!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="margin-top: 32px; padding: 24px; background: #F8FAFC; border-radius: 16px; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <h4 style="margin: 0 0 4px 0;">Looking for a more detailed report?</h4>
                    <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted);">Download your full earning history in CSV or PDF format.</p>
                </div>
                <button class="btn btn-outline" style="border-radius: 10px;">Download Report</button>
            </div>
        </div>
    </div>
</div>

<div class="view-section" id="view-profile">
    <div class="profile-hero fade-up">
        <div class="profile-avatar-lg" style="background: var(--secondary);">@User.Identity.Name.Substring(0,1).ToUpper()</div>
        <div class="profile-hero-info">
            <h2 class="profile-hero-name">@ViewBag.FullName</h2>
            <p class="profile-hero-email">@User.Identity.Name • Member since @ViewBag.MemberSince</p>
        </div>
    </div>

    <form id="profileForm">
        @Html.AntiForgeryToken()
        <div class="profile-grid fade-up" style="animation-delay: 0.1s;">
            <div class="card-section">
                <div class="table-header">
                    <h3>Personal Information</h3>
                    <p>Basic details for your service provider profile</p>
                </div>
                <div style="padding: 28px;">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="FullName" value="@ViewBag.FullName" required>
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="text" name="PhoneNumber" value="@ViewBag.PhoneNumber" required>
                    </div>
                    <div class="form-group">
                        <label>Base Location / City</label>
                        <input type="text" name="Location" value="@ViewBag.UserLocation" required autocomplete="off">
                        <p style="font-size: 0.7rem; color: var(--text-muted); margin-top: 4px;">Used for nearby job routing.</p>
                    </div>
                </div>
            </div>

            <div class="card-section">
                <div class="table-header">
                    <h3>Account Security</h3>
                    <p>Manage your password and access</p>
                </div>
                <div style="padding: 28px;">
                    <button type="button" class="btn btn-outline" style="width: 100%; justify-content: start;" onclick="showNotification('Password reset link sent to your email.', 'success')">
                        <i class="fa-solid fa-key" style="margin-right: 12px; color: var(--primary);"></i> Change Password
                    </button>
                    <div style="margin-top: 24px; padding: 16px; background: var(--bg-arctic); border-radius: 12px; border: 1px solid var(--border);">
                        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">
                            Account Category: <strong style="color: var(--text);">@ViewBag.UserRole</strong>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 8px;">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save Profile</button>
        </div>
    </form>
</div>

<div class="view-section" id="view-settings">

    <div class="profile-hero fade-up">
        <div class="profile-avatar-lg" style="background: var(--secondary);"><i class="fa-solid fa-briefcase" style="font-size:1.5rem;"></i></div>
        <div class="profile-hero-info">
            <h2 class="profile-hero-name">Business Settings</h2>
            <p class="profile-hero-email">Manage your banking details and service preferences</p>
            <p style="margin-top: 8px;">Your business status: 
                @if (ViewBag.IsApproved == true)
                {
                    <span class="badge badge-active"><i class="fa-solid fa-circle-check"></i> Verified & Approved</span>
                }
                else
                {
                    <span class="badge badge-pending" style="background: #FFFBEB; color: #B45309; border: 1px solid #FDE68A;"><i class="fa-solid fa-clock"></i> Pending Approval</span>
                }
            </p>
        </div>
        <div style="margin-left: auto; text-align: right;">
             <div style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; margin-bottom: 4px;">Business Balance</div>
             <div style="font-size: 1.5rem; font-weight: 800; color: #10B981;">R @((ViewBag.TotalEarned ?? 0).ToString("N2"))</div>
        </div>
    </div>

    @if (ViewBag.IsApproved != true)
    {
        <div class="glass-card fade-up" style="margin-bottom: 32px; background: linear-gradient(135deg, #FFFBEB, #FEF3C7); border: 1px solid #FDE68A; padding: 24px; border-radius: 20px; display: flex; align-items: center; gap: 24px;">
            <div style="width: 60px; height: 60px; background: white; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #D97706; box-shadow: var(--shadow-sm);">
                <i class="fa-solid fa-user-shield"></i>
            </div>
            <div style="flex: 1;">
                <h3 style="color: #92400E; margin-bottom: 4px;">Account Pending Verification</h3>
                <p style="color: #B45309; margin: 0; font-size: 0.95rem;">Our administration team is currently reviewing your profile and documents. You will be notified via email once you are approved to submit bids and start earning.</p>
            </div>
        </div>
    }

    <form id="businessSettingsForm">
        @Html.AntiForgeryToken()
        <div class="profile-grid fade-up" style="animation-delay:0.1s;">

            <div class="card-section">
                <div class="table-header">
                    <div><h3>Payout Details</h3><p>Banking information for receiving payments</p></div>
                    <i class="fa-solid fa-building-columns" style="color:var(--secondary);font-size:1.2rem;opacity:0.4;"></i>
                </div>
                <div style="padding:28px;">
                    <div class="form-group">
                        <label>Bank Name</label>
                        <select name="bankName">
                            <option value="">Select your bank</option>
                            <option @(ViewBag.BankName == "FNB / First National Bank" ? "selected" : "")>FNB / First National Bank</option>
                            <option @(ViewBag.BankName == "Standard Bank" ? "selected" : "")>Standard Bank</option>
                            <option @(ViewBag.BankName == "ABSA" ? "selected" : "")>ABSA</option>
                            <option @(ViewBag.BankName == "Nedbank" ? "selected" : "")>Nedbank</option>
                            <option @(ViewBag.BankName == "Capitec" ? "selected" : "")>Capitec</option>
                            <option @(ViewBag.BankName == "TymeBank" ? "selected" : "")>TymeBank</option>
                        </select>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        <div class="form-group">
                            <label>Account Number</label>
                            <input type="text" name="accountNumber" placeholder="e.g. 62012345678" value="@ViewBag.AccountNumber">
                        </div>
                        <div class="form-group">
                            <label>Branch Code</label>
                            <input type="text" name="branchCode" placeholder="e.g. 250655" value="@ViewBag.BranchCode">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Account Type</label>
                        <select name="accountType">
                            <option @(ViewBag.AccountType == "Cheque / Current Account" ? "selected" : "")>Cheque / Current Account</option>
                            <option @(ViewBag.AccountType == "Savings Account" ? "selected" : "")>Savings Account</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="card-section">
                <div class="table-header">
                    <div><h3>Service Configuration</h3><p>Control how you receive job leads</p></div>
                    <i class="fa-solid fa-sliders" style="color:var(--primary);font-size:1.2rem;opacity:0.4;"></i>
                </div>
                <div style="padding:28px;">
                    <div class="form-group" style="margin-bottom:20px;">
                        <label>Service Radius <span id="radiusVal" style="color:var(--primary);font-weight:800;">@(ViewBag.ServiceRadius ?? 15)</span> km</label>
                        <input type="range" min="1" max="100" value="@(ViewBag.ServiceRadius ?? 15)" name="serviceRadius"
                               oninput="document.getElementById('radiusVal').textContent=this.value"
                               style="width:100%;accent-color:var(--primary);margin-top:4px;">
                    </div>
                    <div class="form-group" style="margin-bottom:20px;">
                        <label>Availability Status</label>
                        <select name="availability">
                            <option @(ViewBag.Availability == "Available - Accepting new jobs" ? "selected" : "")>Available - Accepting new jobs</option>
                            <option @(ViewBag.Availability == "Busy - Temporarily unavailable" ? "selected" : "")>Busy - Temporarily unavailable</option>
                            <option @(ViewBag.Availability == "On Leave" ? "selected" : "")>On Leave</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Professional Bio / About</label>
                        <textarea name="about" placeholder="Tell customers about your expertise and services..." 
                                  style="width:100%; height:100px; padding:12px; border:1px solid var(--border); border-radius:10px; font-family:inherit; resize:none;">@ViewBag.About</textarea>
                    </div>
                </div>
            </div>

        </div>

        <div class="card-section fade-up" style="animation-delay:0.2s;">
            <div style="padding:24px 28px;display:flex;align-items:flex-start;gap:20px;">
                <div style="flex:1;">
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
                        <i class="fa-solid fa-bolt" style="color:var(--accent);font-size:1.1rem;"></i>
                        <span style="font-weight:800;font-size:1rem;">Instant Payouts</span>
                        <span style="font-size:0.75rem;font-weight:700;background:var(--accent-light);color:var(--accent);padding:2px 8px;border-radius:99px;text-transform:uppercase;">2.5% fee</span>
                    </div>
                    <p style="font-size:0.88rem;color:var(--text-muted);line-height:1.6;">
                        Funds released immediately after admin approval instead of the standard 48-hour window.
                    </p>
                </div>
                <label class="toggle-switch" style="flex-shrink:0;margin-top:4px;">
                    <input type="checkbox" name="isInstantPayment" value="true" @(ViewBag.IsInstantPayment == true ? "checked" : "")>
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div style="display:flex;justify-content:flex-end;gap:12px;margin-top:8px;">
            <button type="button" class="btn btn-outline" onclick="location.reload()">Discard Changes</button>
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save Business Profile</button>
        </div>
    </form>
</div>

@section scripts {
    <script>
        // Messaging - Mark as read when entering messages tab
        $(function() {
            // Listen for section switches (defined in _Layout.cshtml)
            const originalSwitchSection = window.switchSection;
            window.switchSection = function(id, element) {
                originalSwitchSection(id, element);
                if (id === 'messages') {
                    markMessagesRead();
                }
            };
        });

        function markMessagesRead() {
            $.post('@Url.Action("MarkMessagesAsRead", "Dashboard")', {
                '__RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            }, function(res) {
                if (res.success) {
                    $('.unread-message div[title="New message"]').fadeOut();
                    $('.unread-message').removeClass('unread-message').css({
                        'border-color': 'var(--primary-light)',
                        'background': 'rgba(var(--primary-rgb), 0.02)'
                    });
                }
            });
        }


        function openBidModal(id, title) {
            trackView(id);
            $('#bidRequestId').val(id);
            $('#bidTitle').text('Bid for: ' + title);
            $('#bidModal').css('display', 'flex').hide().fadeIn();
        }

        function trackView(id) {
            $.post('@Url.Action("IncrementViewCount", "Provider")', { requestId: id });
        }

        function openCompleteModal(id, title) {
            $('#completeRequestId').val(id);
            $('#completeModal').css('display', 'flex').hide().fadeIn();
        }

        $('#completeForm').on('submit', function(e) {
            e.preventDefault();
            const btn = $(this).find('button[type="submit"]');
            const originalText = btn.text();
            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Submitting...');

            const formData = new FormData(this);
            $.ajax({
                url: '@Url.Action("MarkAsCompleted", "Provider")',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function(res) {
                    if (res.success) {
                        showNotification(res.message, 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showNotification(res.message, 'error');
                        btn.prop('disabled', false).text(originalText);
                    }
                },
                error: function() {
                    showNotification("An error occurred while submitting completion proof.", "error");
                    btn.prop('disabled', false).text(originalText);
                }
            });
        });

        $('#businessSettingsForm').on('submit', function(e) {
            e.preventDefault();
            const btn = $(this).find('button[type="submit"]');
            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Saving...');

            $.post('@Url.Action("UpdateBusinessSettings", "Provider")', $(this).serialize(), function(res) {
                showNotification(res.message, res.success ? 'success' : 'error');
                btn.prop('disabled', false).text('Save Business Profile');
                if (res.success) setTimeout(() => location.reload(), 1000);
            });
        });

        $('#profileForm').on('submit', function(e) {
            e.preventDefault();
            const btn = $(this).find('button[type="submit"]');
            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Saving...');

            $.post('@Url.Action("UpdateProfile", "Dashboard")', $(this).serialize(), function(res) {
                showNotification(res.message, res.success ? 'success' : 'error');
                btn.prop('disabled', false).text('Save Profile');
                if (res.success) setTimeout(() => location.reload(), 1000);
            });
        });
    </script>

    @* ── Job Map Modal ── *@
    <div id="jobMapModal" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.6); backdrop-filter:blur(4px); z-index:2100; align-items:center; justify-content:center;">
        <div class="auth-card fade-up" style="max-width: 700px; width: 90%;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <h2 id="jobMapTitle" style="font-size: 1.4rem;">Job Location</h2>
                <button onclick="$('#jobMapModal').fadeOut()" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
            </div>
            <div id="jobMapContainer" style="width: 100%; height: 400px; border-radius: 12px; border: 1px solid var(--border);"></div>
            <div style="margin-top: 16px; font-size: 0.9rem; color: var(--text-muted);">
                <i class="fa-solid fa-circle-info" style="color: var(--primary);"></i> This is the approximate location provided by the customer.
            </div>
        </div>
    </div>

    <script>
        let jMap, jMarker;

        function showJobMap(lat, lng, title) {
            if (lat == 0 || lng == 0) {
                showNotification("No exact coordinates provided for this job.", "info");
                return;
            }

            $('#jobMapTitle').text(title);
            $('#jobMapModal').css('display', 'flex').hide().fadeIn();

            const pos = { lat: parseFloat(lat), lng: parseFloat(lng) };

            if (!jMap) {
                jMap = new google.maps.Map(document.getElementById("jobMapContainer"), {
                    zoom: 15,
                    center: pos,
                    mapTypeControl: false,
                    streetViewControl: false
                });
                jMarker = new google.maps.Marker({
                    position: pos,
                    map: jMap,
                    animation: google.maps.Animation.DROP
                });
            } else {
                jMap.setCenter(pos);
                jMarker.setPosition(pos);
            }
        }
    </script>
}