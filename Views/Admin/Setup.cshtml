@{
    ViewBag.Title = "System Setup & Database Migration";
}

<div class="dash-header fade-up">
    <div>
        <h1 style="font-size: 2.5rem; margin-bottom: 8px;">System Setup</h1>
        <p>Maintain your database and system health</p>
    </div>
</div>

<div class="stats-grid fade-up" style="margin-top: -20px; margin-bottom: 40px; animation-delay: 0.1s;">
    <div class="stat-card">
        <div class="stat-icon" style="background: var(--primary-light); color: var(--primary);">
            <i class="fa-solid fa-database"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">Database</div>
            <div class="stat-label">Schema Management</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: #ECFDF5; color: #10B981;">
            <i class="fa-solid fa-server"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">Live</div>
            <div class="stat-label">Environment</div>
        </div>
    </div>
</div>

<div class="profile-grid fade-up" style="animation-delay: 0.2s;">
    <!-- Database Migration Card -->
    <div class="card-section">
        <div class="table-header">
            <div>
                <h3>Database Migration</h3>
                <p>Sync your live database with the latest schema changes</p>
            </div>
            <i class="fa-solid fa-wand-magic-sparkles" style="color: var(--primary); font-size: 1.5rem; opacity: 0.3;"></i>
        </div>
        <div style="padding: 32px;">
            <div style="background: #F8FAFC; border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 24px;">
                <h4 style="margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-file-code" style="color: var(--primary);"></i>
                    Update Script: update_live_db.sql
                </h4>
                <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">
                    This will execute the migration script against your connected database. 
                    The script is designed to be <strong>safe</strong> (it checks for existence before adding columns or tables).
                </p>
                <ul style="font-size: 0.85rem; color: var(--text-muted); margin-top: 12px; padding-left: 20px;">
                    <li>Adds missing Payouts & Notifications tables</li>
                    <li>Adds IsApproved status for Suppliers</li>
                    <li>Adds Business Profile fields (Bank, About, Radius)</li>
                    <li>Updates Service Request schema</li>
                </ul>
            </div>

            <div style="display: flex; flex-direction: column; gap: 16px;">
                <button id="btnUpdateDb" class="btn btn-primary" style="height: 60px; font-size: 1.1rem; border-radius: 16px;" onclick="runDbUpdate()">
                    <i class="fa-solid fa-play" style="margin-right: 8px;"></i> Run Database Update
                </button>
                
                <div id="updateStatus" style="display: none; padding: 16px; border-radius: 12px; font-weight: 600; text-align: center;"></div>
            </div>
        </div>
    </div>

    <!-- System Info Card -->
    <div class="card-section">
        <div class="table-header">
            <div>
                <h3>System Status</h3>
                <p>Environment and connection details</p>
            </div>
            <i class="fa-solid fa-circle-info" style="color: var(--secondary); font-size: 1.5rem; opacity: 0.3;"></i>
        </div>
        <div style="padding: 32px;">
            <div class="profile-info-row">
                <span class="profile-info-label">Current Environment</span>
                <span class="status-badge status-open">Production</span>
            </div>
            <div class="profile-info-row">
                <span class="profile-info-label">Server Time</span>
                <span>@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
            <div class="profile-info-row" style="border: none;">
                <span class="profile-info-label">App Version</span>
                <span style="font-weight: 700;">2.1.0-modernized</span>
            </div>
            
            <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border);">
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;">
                    Need to review system logs or errors?
                </p>
                <a href="@Url.Action("SystemHealth", "Admin")" class="btn btn-outline" style="width: 100%; border-radius: 12px;">
                    <i class="fa-solid fa-notes-medical"></i> View System Health
                </a>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function runDbUpdate() {
            const btn = $('#btnUpdateDb');
            const status = $('#updateStatus');
            const urlParams = new URLSearchParams(window.location.search);
            const secretKey = urlParams.get('key');
            
            if (!confirm("Are you sure you want to run the database migration? This will execute SQL commands directly against your live database.")) return;

            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Executing Migration...');
            status.hide().removeClass('bg-success-light bg-error-light').css('color', 'inherit');

            $.post('@Url.Action("RunDatabaseUpdate", "Admin")', {
                'key': secretKey,
                '__RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            }, function(res) {
                btn.prop('disabled', false).html('<i class="fa-solid fa-play"></i> Run Database Update');
                status.show().text(res.message);
                
                if (res.success) {
                    status.css({ 'background': '#ECFDF5', 'color': '#065F46', 'border': '1px solid #A7F3D0' });
                    showNotification("Database Sync Successful!", "success");
                } else {
                    status.css({ 'background': '#FEF2F2', 'color': '#991B1B', 'border': '1px solid #FECACA' });
                    showNotification("Migration Failed", "error");
                }
            }).fail(function() {
                btn.prop('disabled', false).html('<i class="fa-solid fa-play"></i> Run Database Update');
                status.show().text("A server error occurred while executing the script.").css({ 'background': '#FEF2F2', 'color': '#991B1B', 'border': '1px solid #FECACA' });
            });
        }
    </script>
}

<style>
    .bg-success-light { background: #ECFDF5; color: #065F46; }
    .bg-error-light { background: #FEF2F2; color: #991B1B; }
    .profile-info-row { display: flex; justify-content: space-between; padding: 16px 0; border-bottom: 1px solid var(--border); }
    .profile-info-label { color: var(--text-muted); font-weight: 600; }
</style>
